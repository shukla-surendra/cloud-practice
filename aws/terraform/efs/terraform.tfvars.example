# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.

region  = "us-east-1"
project = "aws-mastery-efs"

# false = Standard (multi-AZ, resilient). true = One Zone (single AZ, ~half cost).
one_zone = false

# elastic (recommended) | bursting | provisioned
throughput_mode              = "elastic"
provisioned_throughput_mibps = 0     # only used if throughput_mode = "provisioned"

# Lifecycle tiering to Infrequent Access (empty string to disable):
transition_to_ia = "AFTER_30_DAYS"

# CIDR allowed to reach NFS 2049. Empty = the default VPC's CIDR.
# In production, replace the SG rule with a reference to your CLIENT security group.
client_cidr = ""
